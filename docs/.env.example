# Environment Variables Example

# Jira Configuration
# Configure these in your .env.local file

NEXT_PUBLIC_JIRA_DOMAIN=your-domain.atlassian.net
NEXT_PUBLIC_JIRA_USER_EMAIL=your-email@company.com
NEXT_PUBLIC_JIRA_API_TOKEN=your-api-token-here
NEXT_PUBLIC_JIRA_BOARD_ID=your-board-id

# Optional: Override default port
# PORT=3000