# Credenciais Jira (usadas como padrão pelo servidor — não vão para o client)
JIRA_DOMAIN=empresa.atlassian.net
JIRA_EMAIL=seu@email.com
JIRA_API_TOKEN=seu_api_token
JIRA_BOARD_ID=1

# tickets-apiv2 (autenticação de usuário)
TICKETS_API_URL=https://api.acessofacil.com/v2
# Header Origin enviado para a API resolver a empresa (CompanyMiddleware)
TICKETS_COMPANY_ORIGIN=https://meubilhete.com.br
